# Copy to .env.local and adjust paths for your machine.

# Where the Rust backend's TLS entrypoint (nginx sidecar) is reachable.
BACKEND_URL=https://localhost:8443

# Path (relative to this project's root) to the local dev CA that signed the
# backend's TLS cert. Generate it with:
#   cd ../cert-service && ./scripts/generate-certs.sh
BACKEND_CA_CERT_PATH=../cert-service/certs/ca.crt

# Only needed if running against the mTLS nginx config
# (docker-compose.mtls.yml). Leave unset for plain TLS.
# BACKEND_CLIENT_CERT_PATH=../cert-service/certs/client.crt
# BACKEND_CLIENT_KEY_PATH=../cert-service/certs/client.key
